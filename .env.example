# 이 파일을 .env 로 복사한 뒤 실제 값을 채우세요:  cp .env.example .env
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# 쉼표로 여러 길드 지정 가능. 비우면 글로벌 등록(반영 최대 1시간)
DISCORD_GUILD_ID=
# 프리픽스 커맨드 접두사. 비우면 슬래시 전용으로 동작 (MESSAGE CONTENT INTENT 불필요)
BOT_PREFIX=

# 구글 캘린더 연동 (선택). 서비스 계정 키 JSON을 secrets/ 에 두고 캘린더 ID를 입력
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/google-service-account.json
